{
  "expo": {
    "name": "Namaz Alışkanlığı",
    "slug": "namaz-aliskanligi",
    "version": "1.0.4",
    "orientation": "portrait",
    "scheme": "namaz-aliskanligi",
    "userInterfaceStyle": "automatic",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#121414"
    },
    "android": {
      "package": "com.trs1342.namazaliskanligi",
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "POST_NOTIFICATIONS",
        "VIBRATE",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#121414"
      }
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.trs1342.namazaliskanligi",
      "icon": "./assets/icon.png",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Namaz vakitlerini konumunuza göre hesaplamak için konum izni gereklidir."
      }
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Namaz vakitlerini konumunuza göre hesaplamak için konum izni gereklidir."
        }
      ],
      [
        "expo-notifications",
        {
          "defaultChannel": "default"
        }
      ],
      "expo-asset",
      "expo-audio"
    ],
    "newArchEnabled": true,
    "extra": {
      "eas": {
        "projectId": "be653af0-e81b-4c97-b17a-c3bb5fae2d9a"
      }
    }
  }
}
